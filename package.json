		"vite": "^8.0.16"
	},
	"dependencies": {
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@lucide/svelte": "^1.21.0"
	}
